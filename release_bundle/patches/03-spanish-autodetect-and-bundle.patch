++    text = re.sub(r"\bD[Rr]\.(?= [A-Z])", "Doctor", text)
++    text = re.sub(r"\b(?:Mr\.|MR\.(?= [A-Z]))", "Mister", text)
++    text = re.sub(r"\b(?:Ms\.|MS\.(?= [A-Z]))", "Miss", text)
++    text = re.sub(r"\b(?:Mrs\.|MRS\.(?= [A-Z]))", "Mrs", text)
